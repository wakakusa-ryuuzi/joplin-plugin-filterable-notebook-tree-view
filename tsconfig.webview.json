{
  "compilerOptions": {
    "composite": true,

    "module": "esnext",
    "target": "es2015",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,

    "baseUrl": "src/webview",
    "outDir": "./dist-webview/",
  },
  "include": [
    "src/webview/**/*.ts", "src/webview/**/*.d.ts", "src/webview/**/*.vue",
    "api/**/*.d.ts" , "api/**/*.ts",
    "src/share/**/*.ts",
    "uno.config.mts"
]
}
